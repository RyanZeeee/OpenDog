      "link": null,
      "locked": false,
      "text": "A. 工具从哪里来？",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A. 工具从哪里来？",
      "lineHeight": 1.25,
      "baseline": 26,
      "autoResize": false,
      "index": "bBA"
    },
    {
      "id": "tools_text_bw",
      "type": "text",
      "x": 1287.9338327015598,
      "y": 291.1696997470963,
      "width": 360,
      "height": 118.75,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "g9mjtV4HYTr2lnc2zjK3Y"
      ],
      "frameId": null,
      "roundness": null,
      "seed": 1947531265,
      "version": 288,
      "versionNonce": 1768762993,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782184447055,
      "link": null,
      "locked": false,
      "text": "builtin：opendog 自带工具\nplugin：workspace/plugins 插件\nmcpServers：外部 MCP 服务配置\n\n注意：这些最后都会进入 ToolRegistry",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "builtin：opendog 自带工具\nplugin：workspace/plugins 插件\nmcpServers：外部 MCP 服务配置\n\n注意：这些最后都会进入 ToolRegistry",
      "lineHeight": 1.25,
      "baseline": 89,
      "autoResize": false,
      "index": "bBB"
    },
    {
