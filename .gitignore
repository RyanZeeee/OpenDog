.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
node_modules/
*.log
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
.claude/
.codex/
.opendog_tmp/
docs/PROJECT_CONTEXT.md

# Personal runtime configuration
workspace/config.user.yaml
workspace/.runtime/

# Local conversation and generated runtime history
src/opendog/.history/

# User-created cron jobs and memories are local state.
workspace/crons/*
!workspace/crons/.gitkeep
workspace/memories/topics/*
!workspace/memories/topics/.gitkeep
workspace/memories/projects/*
!workspace/memories/projects/.gitkeep
workspace/memories/daily-notes/*
!workspace/memories/daily-notes/.gitkeep
